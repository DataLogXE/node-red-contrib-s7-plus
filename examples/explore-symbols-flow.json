    {
        "id": "exp_fn_meta",
        "type": "function",
        "z": "explore_tab",
        "name": "Browse summary",
        "func": "const m = msg.meta || {};\n\nmsg.payload = {\n    symbolCount: m.symbolCount,\n    dbCount: m.dbCount,\n    durationMs: m.durationMs,\n    limitExceeded: m.limitExceeded,\n    maxSymbols: m.maxSymbols,\n    limitMessage: m.limitMessage\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 620,
        "y": 200,
        "wires": [
            [
                "exp_debug_meta"
            ]
        ]
    },
