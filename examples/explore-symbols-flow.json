    {
        "id": "exp_fn_to_read",
        "type": "function",
        "z": "explore_tab",
        "name": "Pick symbols → read",
        "func": "const pick = [\n    \"DB_TestSignals.Low.Sawtooth_LReal\",\n    \"DB_TestSignals.Mid.Sine_LReal\"\n];\n\nmsg.symbols = msg.payload.filter(s => pick.includes(s));\n\nif (msg.symbols.length === 0) {\n    msg.symbols = pick;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 980,
